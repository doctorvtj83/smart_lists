# Copy to `.env` and fill in real values (`.env` is gitignored).
# Neon Postgres connection URL — main branch (development)
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"

# Auth.js — generate with: npx auth secret
AUTH_SECRET=""

# Google OAuth (https://console.cloud.google.com → Credentials → OAuth client ID)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
