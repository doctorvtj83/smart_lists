# Dependencies (added when Slice 1 scaffold exists)
node_modules/

# Next.js build output
.next/
out/

# Environment files with real secrets — never commit
.env
.env.test
.env*.local

# .env.example is the committed template (no real values)

# Prisma
/prisma/*.db
/prisma/*.db-journal

# Vitest / test coverage
coverage/

# OS / editor
.DS_Store
*.pem

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Vercel
.vercel

# Git worktrees used by agent workflows; ignored so nested checkouts are never tracked.
.worktrees/
